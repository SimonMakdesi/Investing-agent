rice.\n\n---\n\n```json\n{\n  \"market_read\": \"Swedish large-caps broadly weak over 3 months with industrials and defensives 8-15% off highs; large insider buying clusters in H&M and Essity dominate the signal landscape this week, pointing to potential value entries after pullbacks.\",\n  \"picks\": [\n    {\n      \"ticker\": \"HM-B.ST\",\n      \"name\": \"H&M\",\n      \"angle\": \"controlling family bought ~445M SEK in three tranches on May 21 while stock is 16% below 52-week high and below 200-day MA\",\n      \"sleeve_hint\": \"core\"\n    },\n    {\n      \"ticker\": \"ESSITY-B.ST\",\n      \"name\": \"Essity B\",\n      \"angle\": \"board member bought ~144M SEK across three days; defensive staples near 200-day MA after 11% drawdown from highs\",\n      \"sleeve_hint\": \"core\"\n    },\n    {\n      \"ticker\": \"SOBI.ST\",\n      \"name\": \"Swedish Orphan Biovitrum\",\n      \"angle\": \"CEO-level buy of 26M SEK on strong 12-month trend; two arrows pointing same direction in specialty pharma\",\n      \"sleeve_hint\": \"core\"\n    },\n    {\n      \"ticker\": \"THULE.ST\",\n      \"name\": \"Thule Group\",\n      \"angle\": \"22M SEK board-level insider buy at 22% discount to 52-week high on quality consumer-outdoor brand\",\n      \"sleeve_hint\": \"core\"\n    },\n    {\n      \"ticker\": \"AAK.ST\",\n      \"name\": \"AAK\",\n      \"angle\": \"small insider buy on defensive food-ingredients compounder trading near 200-day MA at flat 12-month return\",\n      \"sleeve_hint\": \"core\"\n    },\n    {\n      \"ticker\": \"BILL.ST\",\n      \"name\": \"Bilia\",\n      \"angle\": \"10 insider transactions totalling 14M SEK while stock is 42% off highs; aggressive recovery thesis candidate if fundamentals support\",\n      \"sleeve_hint\": \"aggressive\"\n    },\n    {\n      \"ticker\": \"NCC-B.ST\",\n      \"name\": \"NCC B\",\n      \"angle\": \"six insider buys totalling 1M SEK as stock trades 17% below 52-week high; check whether construction sector